# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# MongoDB connection string
MONGODB_URI=

# Session password (REQUIRED in production, min 32 chars) for nuxt-auth-utils
# In dev, it is auto-generated if not set, but in production a missing or short
# password causes a 400 error on every login.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_SESSION_PASSWORD=

HOST=0.0.0.0
PORT=3005

# Google OAuth (https://console.cloud.google.com/)
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Mailing system (SMTP + IMAP)
MAILER_SMTP_HOST=localhost
MAILER_SMTP_PORT=25
MAILER_SMTP_SECURE=false
# MAILER_SMTP_USER=   # optional: only if SMTP requires auth
# MAILER_SMTP_PASS=   # optional: only if SMTP requires auth
MAILER_IMAP_HOST=localhost
MAILER_IMAP_PORT=143
MAILER_IMAP_SECURE=false
MAILER_IMAP_USER=contact
MAILER_IMAP_PASS=
MAILER_FROM="GeneaSphere" <noreply@yourdomain.com>

